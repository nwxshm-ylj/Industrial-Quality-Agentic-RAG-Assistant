# Copy this file to .env.production and replace every CHANGE_ME value.
# Never commit the real .env.production file.

ENVIRONMENT=production

# PostgreSQL
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=CHANGE_ME_URL_SAFE_DB_PASSWORD
POSTGRES_DB=industrial_rag
DATABASE_URL=postgresql+psycopg2://rag_user:CHANGE_ME_URL_SAFE_DB_PASSWORD@postgres:5432/industrial_rag

# Qdrant: applications query the stable Alias, not the physical version name.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=industrial_docs_qwen_1024_v1
QDRANT_COLLECTION_ALIAS=industrial_docs_active

# Qwen embedding
EMBEDDING_PROVIDER=qwen
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_EMBEDDING_DIMENSION=1024
QWEN_EMBEDDING_API_KEY=CHANGE_ME_QWEN_EMBEDDING_KEY
QWEN_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding
EMBEDDING_INDEX_VERSION=qwen-1024-v1

# OpenSearch. Use HTTPS and credentials for a real production cluster.
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX_PREFIX=industrial_docs
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_CERTS=false
KEYWORD_SEARCH_BACKEND=opensearch
HYBRID_DEGRADED_MODE=vector_only

# LLM
LLM_PROVIDER=qwen
LLM_MODEL=qwen-plus
LLM_API_KEY=CHANGE_ME_LLM_API_KEY
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Authentication. Generate a unique random secret of at least 32 characters.
JWT_SECRET_KEY=CHANGE_ME_RANDOM_SECRET_AT_LEAST_32_CHARACTERS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Prompt release
PROMPT_CATALOG_PATH=prompts/catalog
PROMPT_RELEASE_PATH=prompts/releases/stable.yaml
PROMPT_VALIDATE_ON_STARTUP=true
PROMPT_EXPOSE_VERSION_IN_RESPONSE=true

# Observability. Content capture should remain disabled unless approved.
TELEMETRY_ENABLED=true
METRICS_ENABLED=true
USAGE_ANALYTICS_ENABLED=true
TELEMETRY_CAPTURE_CONTENT=false
OTEL_SERVICE_NAME=industrial-quality-rag-api
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACE_SAMPLE_RATIO=0.1

REACT_WEB_PORT=30080
