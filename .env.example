QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=industrial_docs_qwen_1024_v1
QDRANT_COLLECTION_ALIAS=industrial_docs_active
LEGACY_QDRANT_COLLECTION=industrial_docs
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_PROVIDER=qwen
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_EMBEDDING_DIMENSION=1024
QWEN_EMBEDDING_API_KEY=your_api_key_here
QWEN_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding
QWEN_EMBEDDING_BATCH_SIZE=10
EMBEDDING_INDEX_VERSION=qwen-1024-v1

OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX_PREFIX=industrial_docs
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_CONNECT_TIMEOUT=5
OPENSEARCH_READ_TIMEOUT=10
OPENSEARCH_POOL_MAXSIZE=20
OPENSEARCH_MAX_RETRIES=3
OPENSEARCH_RETRY_ON_TIMEOUT=true
KEYWORD_SEARCH_BACKEND=opensearch
KEYWORD_INDEX_VERSION=v1
HYBRID_DEGRADED_MODE=vector_only

ENVIRONMENT=development
TELEMETRY_ENABLED=true
METRICS_ENABLED=true
USAGE_ANALYTICS_ENABLED=true
OTEL_SERVICE_NAME=industrial-quality-rag-api
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACE_SAMPLE_RATIO=1.0
OTEL_EXPORT_TIMEOUT_SECONDS=5
TELEMETRY_CAPTURE_CONTENT=false
MODEL_PRICING_PATH=data/config/model_pricing.yaml
USAGE_RETENTION_DAYS=90
USAGE_BACKGROUND_WORKERS=4
USAGE_BACKGROUND_MAX_PENDING=1000

LLM_MODEL=qwen-plus
LLM_PROVIDER=qwen
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Prompt Catalog 与发布版本。生产环境应只切换经过评估的 Release Manifest。
PROMPT_CATALOG_PATH=prompts/catalog
PROMPT_RELEASE_PATH=prompts/releases/stable.yaml
PROMPT_VALIDATE_ON_STARTUP=true
PROMPT_EXPOSE_VERSION_IN_RESPONSE=true

POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=industrial_rag
DATABASE_URL=postgresql+psycopg2://rag_user:rag_password@localhost:5432/industrial_rag

RERANKER_MODEL=BAAI/bge-reranker-base
USE_RERANKER=false

JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
PROMETHEUS_RETENTION=15d

# React Nginx 宿主端口。Windows 可能保留 3000，默认使用 30080。
REACT_WEB_PORT=30080
